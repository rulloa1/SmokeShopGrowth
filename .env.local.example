# ── Email SMTP Configuration ────────────────
# IMPORTANT: Use Gmail App Password (NOT your main password)
# Get it from: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_16_chars
FROM_EMAIL=your.email@gmail.com
FROM_NAME=Your Name | Web Design

# ── Third-party APIs ────────────────────────
# Get these from your respective dashboards
OPENAI_API_KEY=sk-your-key-here
ELEVENLABS_API_KEY=sk-your-key-here
VAPI_API_KEY=your-api-key-here

# ── Demo Configuration ──────────────────────
DEMO_BASE_URL=https://your-demo-domain.com

# ── Webhook Configuration ──────────────────
WEBHOOK_URL=https://your-ngrok-url.ngrok.io/vapi/webhook
